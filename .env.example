PORT=3847
# Behind reverse proxy only (optional):
# TRUST_PROXY=1
# TRUST_PROXY_HOPS=1

WEBHOOK_SECRET=generate-a-long-random-string

ACTUAL_SERVER_URL=https://actual.example.com
ACTUAL_SERVER_PASSWORD=server-login-password
ACTUAL_BUDGET_SYNC_ID=paste-from-settings-advanced-sync-id
# If the budget file uses E2E encryption:
# ACTUAL_BUDGET_FILE_PASSWORD=

ACTUAL_DATA_DIR=./.actual-data
ACTUAL_VERBOSE=0

# Map bank "account ending" (last 4 or full suffix) to Actual account UUID.
# Run: npm run print-budget-ids   (copies ids from your synced budget)
ACTUAL_ACCOUNT_MAP={"0646":"xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"}

# Default category for webhook imports (create a category named "UPI" in Actual, or set id explicitly):
# ACTUAL_DEFAULT_CATEGORY_NAME=UPI
# ACTUAL_DEFAULT_CATEGORY_ID=

# --- Docker Compose (optional; see DEPLOY.md) ---
# COMPOSE_PROJECT_NAME=actual-helper
# ACTUAL_HELPER_PUBLISH_PORT=3847
# ACTUAL_HELPER_VOLUME=actual_helper_data
# Tag for locally built image: docker compose build tags this:
# ACTUAL_HELPER_IMAGE_REF=actual-helper:local
# Prebuilt deploy only — use docker-compose.registry.yml and set to your image, e.g.:
# ACTUAL_HELPER_IMAGE_REF=ghcr.io/your-org/your-repo:v1.0.0
